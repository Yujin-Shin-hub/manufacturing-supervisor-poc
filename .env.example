# LLM provider
# - auto: Qwen 우선, 실패 시 OpenAI 사용
# - qwen: Qwen/OpenAI-compatible endpoint만 사용
# - openai: OpenAI API만 사용
LLM_PROVIDER=auto

# 기본: 로컬 Ollama Qwen (오픈소스, 키 불필요 — ollama pull qwen2.5:7b 후 사용)
QWEN_API_KEY=ollama
QWEN_BASE_URL=http://localhost:11434/v1
QWEN_MODEL_NAME=qwen2.5:7b

# 대안: DashScope 클라우드 API 사용 시 (키 발급 필요)
# QWEN_API_KEY=your-dashscope-api-key
# QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# QWEN_MODEL_NAME=qwen-plus

# OpenAI fallback/provider 사용 시
# OPENAI_API_KEY=your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL_NAME=gpt-4.1-mini

# MQTT sensor stream (roadmap step 10)
# Mosquitto는 별도 설치/실행 필요: https://mosquitto.org/download/
MQTT_ENABLED=false
MQTT_HOST=localhost
MQTT_PORT=1883
